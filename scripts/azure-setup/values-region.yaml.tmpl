# daytona-region (BYOC) helm values - Azure / AKS, K8s-native flow.
# Rendered by scripts/azure-setup/up.sh via envsubst against operator prompts.
#
# Required ${VAR} placeholders (set by up.sh from prompts or computed):
#   BASE_DOMAIN                  - public DNS base, e.g. byoc.example.com
#   REGION_NAME                  - Daytona region name
#   DAYTONA_API_URL              - Daytona Cloud API URL
#   DAYTONA_API_KEY              - Daytona Cloud admin API key (secret)
#   AZURE_REGION                 - Azure region, e.g. eastus
#   BLOB_BUCKET                  - Azure Blob container name (snapshot storage)
#   RCLONE_GATEWAY_ENDPOINT      - in-cluster S3 facade for Azure Blob, e.g. http://rclone-s3-gateway.daytona-region:8080
#   RCLONE_ACCESS_KEY            - rclone gateway access key (matches the gateway Secret)
#   RCLONE_SECRET_KEY            - rclone gateway secret key (matches the gateway Secret)
#   RUNNER_AWS_CREDENTIAL_MODE   - "static" (Azure Workload Identity wiring is a Prompt 2 deliverable)
#   AZURE_CLIENT_ID              - Azure WI client ID (empty in Prompt 1; placeholder for Prompt 2)
#   RUNNER_IMAGE_TAG             - daytona-runner image tag
#   INTERNAL_REGISTRY_HOST       - optional cluster-DNS hostname for an internal Docker registry (empty = none)
#
# IMPORTANT (Azure-specific): Azure Blob is NOT natively S3-compatible. The
# snapshot-manager + runner talk to an in-cluster `rclone-s3-gateway` deployment
# that proxies S3 calls to Azure Blob. up.sh applies rclone-deployment.yaml.tmpl
# BEFORE helm install daytona-region.

baseDomain: "${BASE_DOMAIN}"
regionName: "${REGION_NAME}"
proxyUrl: "https://proxy.${BASE_DOMAIN}"
snapshotManagerUrl: "https://snapshots.${BASE_DOMAIN}"
daytonaApiUrl: "${DAYTONA_API_URL}"
daytonaApiKey: "${DAYTONA_API_KEY}"

global:
  storageClass: "managed-csi"

registration:
  enabled: true

services:
  proxy:
    ingress:
      enabled: true
      className: "nginx"
      tls: true
      selfSigned: false
      annotations:
        cert-manager.io/cluster-issuer: "letsencrypt-prod"
        nginx.ingress.kubernetes.io/ssl-redirect: "true"
        nginx.ingress.kubernetes.io/proxy-read-timeout: "3600"
        nginx.ingress.kubernetes.io/proxy-send-timeout: "3600"

  snapshotManager:
    enabled: true
    logLevel: "info"
    ingress:
      enabled: true
      className: "nginx"
      hostname: "snapshots.${BASE_DOMAIN}"
      tls: true
      annotations:
        cert-manager.io/cluster-issuer: "letsencrypt-prod"
        nginx.ingress.kubernetes.io/ssl-redirect: "true"
    storage:
      s3:
        # rclone gateway is opaque to S3 region; any value works.
        region: "us-east-1"
        bucket: "${BLOB_BUCKET}"
        accessKey: "${RCLONE_ACCESS_KEY}"
        secretKey: "${RCLONE_SECRET_KEY}"
        endpoint: "${RCLONE_GATEWAY_ENDPOINT}"
        encrypt: false
        secure: false
        deleteEnabled: true

  runner:
    mainContainer:
      enabled: true
    ports:
      api: 3000
      ssh: 2220
    hostPaths:
      varLibDaytona: /var/lib/daytona
    aws:
      credentialMode: "${RUNNER_AWS_CREDENTIAL_MODE}"
      allowEmptyStaticKeyShim: false
    serviceAccount:
      create: true
      annotations:
        # Azure Workload Identity placeholder (Prompt 2 deliverable). Empty in Prompt 1.
        azure.workload.identity/client-id: "${AZURE_CLIENT_ID}"
      automountServiceAccountToken: true
    env:
      # Runner uses the same rclone gateway as snapshot-manager.
      AWS_REGION: "us-east-1"
      AWS_ENDPOINT_URL: "${RCLONE_GATEWAY_ENDPOINT}"
      AWS_DEFAULT_BUCKET: "${BLOB_BUCKET}"
      AWS_ACCESS_KEY_ID: "${RCLONE_ACCESS_KEY}"
      AWS_SECRET_ACCESS_KEY: "${RCLONE_SECRET_KEY}"
    dockerInstaller:
      dynamicHostAliases: []
      insecureRegistries: []
