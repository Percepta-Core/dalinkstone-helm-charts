# daytona-region (BYOC) helm values — GCP (GKE) reproducer.
# Substituted via envsubst at runtime. The repro.sh script renders this
# template with: DOMAIN, REGION_NAME, DAYTONA_API_URL, DAYTONA_API_KEY,
# GCS_BUCKET, GCS_LOCATION, HMAC_ACCESS_KEY, HMAC_SECRET_KEY.
#
# The rendered file lives only in mktemp memory during `helm install` and
# is shred'd immediately after. The actual HMAC values are stored in
# Google Secret Manager — the .state directory only ever sees the resource
# names of those secrets, never their plaintext content.

# Region name registered with Daytona Cloud. Must be lowercase + alphanumeric
# plus . _ - .  Auto-generated by repro.sh with a timestamp suffix.
regionName: "${REGION_NAME}"

# Public URL where the proxy will be reachable. Daytona Cloud stores this
# value when registering the region and SDK calls targeting this region
# route through it.
proxyUrl: "https://proxy.${DOMAIN}"

# Public URL of the snapshot manager. Stores both snapshot blobs and
# declarative-builder build context in the customer-owned GCS bucket below.
snapshotManagerUrl: "https://snapshots.${DOMAIN}"

# Daytona Cloud API. For self-hosted Daytona this would be your own URL,
# but BYOC customers point at the public Cloud control plane.
daytonaApiUrl: "${DAYTONA_API_URL}"
daytonaApiKey: "${DAYTONA_API_KEY}"

global:
  # GKE default storage class. `standard-rwo` is the modern persistent disk
  # default on GKE (block storage, ReadWriteOnce). `standard` (in-tree) and
  # `premium-rwo` (SSD) also exist.
  storageClass: "standard-rwo"

# Region registration hook is enabled by default - leave it on. The chart's
# pre-install hook calls POST /api/regions, stores the response (region ID,
# proxyApiKey, sshGatewayApiKey, snapshotManagerUsername, snapshotManagerPassword)
# into a Kubernetes secret named `<release>-region-config`.
registration:
  enabled: true

services:
  proxy:
    ingress:
      enabled: true
      className: "nginx"
      tls: true
      selfSigned: false
      annotations:
        nginx.ingress.kubernetes.io/ssl-redirect: "true"
        # Sandboxes can hold long-running websocket connections + interactive sessions.
        nginx.ingress.kubernetes.io/proxy-read-timeout: "3600"
        nginx.ingress.kubernetes.io/proxy-send-timeout: "3600"
        # Users may upload large files into sandboxes (via dashboard, SDK).
        # ingress-nginx defaults to a 1 MB body limit; "0" disables it.
        nginx.ingress.kubernetes.io/proxy-body-size: "0"
        # Stream the body to the upstream instead of spooling it in nginx;
        # required for chunked uploads to behave correctly through the proxy.
        nginx.ingress.kubernetes.io/proxy-request-buffering: "off"

  snapshotManager:
    enabled: true
    logLevel: "info"
    ingress:
      enabled: true
      className: "nginx"
      hostname: "snapshots.${DOMAIN}"
      tls: true
      annotations:
        nginx.ingress.kubernetes.io/ssl-redirect: "true"
        # Docker registry uploads can be hundreds of MB to GB per layer.
        # ingress-nginx's default 1 MB cap returns 413 Request Entity Too
        # Large on every push without this. "0" disables the cap entirely.
        nginx.ingress.kubernetes.io/proxy-body-size: "0"
        # Don't buffer the entire layer body in nginx before forwarding to
        # the registry — stream it through. Without this, large layers
        # can fail with 413 even when proxy-body-size is set, because
        # nginx's intermediate spool-to-disk has its own limit.
        nginx.ingress.kubernetes.io/proxy-request-buffering: "off"
        # Layer pushes can take minutes for big rootfs images. Default
        # nginx upstream timeouts (60s) are too short.
        nginx.ingress.kubernetes.io/proxy-read-timeout: "3600"
        nginx.ingress.kubernetes.io/proxy-send-timeout: "3600"
    storage:
      s3:
        # GCS interop XML API — uses the SAME customer-owned bucket every
        # runner VM reads/writes for the declarative builder (matching
        # AWS_* env vars in /etc/systemd/system/daytona-runner.service).
        #
        # The snapshot-manager's S3 client just sees an S3-compatible
        # endpoint at storage.googleapis.com; bucket name resolution,
        # multipart uploads, and signed URLs all behave like S3.
        region: "${GCS_LOCATION}"
        bucket: "${GCS_BUCKET}"
        endpoint: "https://storage.googleapis.com"
        accessKey: "${HMAC_ACCESS_KEY}"
        secretKey: "${HMAC_SECRET_KEY}"
        encrypt: false
        secure: true
        deleteEnabled: true
