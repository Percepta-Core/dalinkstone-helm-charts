# daytona-region (BYOC) helm values - GCP / GKE, K8s-native flow.
# Rendered by scripts/gcs-setup/up.sh via envsubst against operator prompts.
#
# Required ${VAR} placeholders (set by up.sh from prompts or computed):
#   BASE_DOMAIN                  - public DNS base, e.g. byoc.example.com
#   REGION_NAME                  - Daytona region name
#   DAYTONA_API_URL              - Daytona Cloud API URL
#   DAYTONA_API_KEY              - Daytona Cloud admin API key (secret)
#   GCS_LOCATION                 - GCS bucket location, e.g. us-central1
#   GCS_BUCKET                   - GCS bucket name (snapshots + build context via interop)
#   HMAC_ACCESS_KEY              - GCS HMAC access ID (tied to service-account)
#   HMAC_SECRET_KEY              - GCS HMAC secret (tied to service-account, secret)
#   RUNNER_AWS_CREDENTIAL_MODE   - "static" (Workload Identity wiring is a Prompt 2 deliverable)
#   GCP_SERVICE_ACCOUNT_EMAIL    - WI placeholder (empty in Prompt 1)
#   RUNNER_IMAGE_TAG             - daytona-runner image tag
#   INTERNAL_REGISTRY_HOST       - optional cluster-DNS hostname for an internal Docker registry (empty = none)
#
# IMPORTANT (GCP-specific): GCS interop XML API at https://storage.googleapis.com
# is S3-compatible enough that snapshot-manager + runner talk to it directly with
# HMAC credentials (no gateway needed, unlike Azure).

baseDomain: "${BASE_DOMAIN}"
regionName: "${REGION_NAME}"
proxyUrl: "https://proxy.${BASE_DOMAIN}"
snapshotManagerUrl: "https://snapshots.${BASE_DOMAIN}"
daytonaApiUrl: "${DAYTONA_API_URL}"
daytonaApiKey: "${DAYTONA_API_KEY}"

global:
  storageClass: "standard-rwo"

registration:
  enabled: true

services:
  proxy:
    ingress:
      enabled: true
      className: "nginx"
      tls: true
      selfSigned: false
      annotations:
        cert-manager.io/cluster-issuer: "letsencrypt-prod"
        nginx.ingress.kubernetes.io/ssl-redirect: "true"
        nginx.ingress.kubernetes.io/proxy-read-timeout: "3600"
        nginx.ingress.kubernetes.io/proxy-send-timeout: "3600"
        # Large file uploads via the dashboard/SDK; "0" disables nginx's 1 MB cap.
        nginx.ingress.kubernetes.io/proxy-body-size: "0"
        nginx.ingress.kubernetes.io/proxy-request-buffering: "off"

  snapshotManager:
    enabled: true
    logLevel: "info"
    ingress:
      enabled: true
      className: "nginx"
      hostname: "snapshots.${BASE_DOMAIN}"
      tls: true
      annotations:
        cert-manager.io/cluster-issuer: "letsencrypt-prod"
        nginx.ingress.kubernetes.io/ssl-redirect: "true"
        # Docker registry layer pushes are hundreds of MB to GB.
        nginx.ingress.kubernetes.io/proxy-body-size: "0"
        nginx.ingress.kubernetes.io/proxy-request-buffering: "off"
        nginx.ingress.kubernetes.io/proxy-read-timeout: "3600"
        nginx.ingress.kubernetes.io/proxy-send-timeout: "3600"
    storage:
      s3:
        region: "${GCS_LOCATION}"
        bucket: "${GCS_BUCKET}"
        endpoint: "https://storage.googleapis.com"
        accessKey: "${HMAC_ACCESS_KEY}"
        secretKey: "${HMAC_SECRET_KEY}"
        encrypt: false
        secure: true
        deleteEnabled: true

  runner:
    mainContainer:
      enabled: true
    ports:
      api: 3000
      ssh: 2220
    hostPaths:
      varLibDaytona: /var/lib/daytona
    aws:
      credentialMode: "${RUNNER_AWS_CREDENTIAL_MODE}"
      allowEmptyStaticKeyShim: false
    serviceAccount:
      create: true
      annotations:
        # GKE Workload Identity placeholder (Prompt 2 deliverable). Empty in Prompt 1.
        iam.gke.io/gcp-service-account: "${GCP_SERVICE_ACCOUNT_EMAIL}"
      automountServiceAccountToken: true
    env:
      AWS_REGION: "${GCS_LOCATION}"
      AWS_ENDPOINT_URL: "https://storage.googleapis.com"
      AWS_DEFAULT_BUCKET: "${GCS_BUCKET}"
      AWS_ACCESS_KEY_ID: "${HMAC_ACCESS_KEY}"
      AWS_SECRET_ACCESS_KEY: "${HMAC_SECRET_KEY}"
    dockerInstaller:
      dynamicHostAliases: []
      insecureRegistries: []
