# daytona-region (BYOC) helm values - AWS / EKS, K8s-native flow.
# Rendered by scripts/aws-setup/up.sh via envsubst against operator prompts.
#
# Required ${VAR} placeholders (set by up.sh from prompts or computed):
#   BASE_DOMAIN                  - public DNS base, e.g. byoc.example.com
#   REGION_NAME                  - Daytona region name (lowercase alnum . _ -)
#   DAYTONA_API_URL              - Daytona Cloud API URL
#   DAYTONA_API_KEY              - Daytona Cloud admin API key (secret)
#   AWS_REGION                   - AWS region, e.g. us-east-1
#   S3_BUCKET                    - S3 bucket name for snapshots + build context
#   RUNNER_AWS_CREDENTIAL_MODE   - "static" or "irsa"
#   IAM_ACCESS_KEY               - IAM user access key (when credentialMode=static, else empty)
#   IAM_SECRET_KEY               - IAM user secret key (when credentialMode=static, else empty)
#   IRSA_ROLE_ARN                - IAM role ARN annotation (when credentialMode=irsa, else empty)
#   RUNNER_IMAGE_TAG             - daytona-runner image tag (default v0.183.0 = chart appVersion)
#   INTERNAL_REGISTRY_HOST       - optional cluster-DNS hostname for an internal Docker registry (empty = none)

baseDomain: "${BASE_DOMAIN}"
regionName: "${REGION_NAME}"
proxyUrl: "https://proxy.${BASE_DOMAIN}"
snapshotManagerUrl: "https://snapshots.${BASE_DOMAIN}"
daytonaApiUrl: "${DAYTONA_API_URL}"
daytonaApiKey: "${DAYTONA_API_KEY}"

global:
  storageClass: "gp3"

registration:
  enabled: true

services:
  proxy:
    ingress:
      enabled: true
      className: "nginx"
      tls: true
      selfSigned: false
      annotations:
        cert-manager.io/cluster-issuer: "letsencrypt-prod"
        nginx.ingress.kubernetes.io/ssl-redirect: "true"
        # Sandboxes hold long-running websocket and interactive sessions.
        nginx.ingress.kubernetes.io/proxy-read-timeout: "3600"
        nginx.ingress.kubernetes.io/proxy-send-timeout: "3600"

  snapshotManager:
    enabled: true
    logLevel: "info"
    ingress:
      enabled: true
      className: "nginx"
      hostname: "snapshots.${BASE_DOMAIN}"
      tls: true
      annotations:
        cert-manager.io/cluster-issuer: "letsencrypt-prod"
        nginx.ingress.kubernetes.io/ssl-redirect: "true"
    storage:
      s3:
        region: "${AWS_REGION}"
        bucket: "${S3_BUCKET}"
        accessKey: "${IAM_ACCESS_KEY}"
        secretKey: "${IAM_SECRET_KEY}"
        encrypt: false
        secure: true
        deleteEnabled: true

  runner:
    # K8s-native runner main container (Prompt 1 deliverable).
    mainContainer:
      enabled: true
    ports:
      api: 3000
      ssh: 2220
    hostPaths:
      varLibDaytona: /var/lib/daytona
    aws:
      # credentialMode: "static" emits AWS_ACCESS_KEY_ID/SECRET into the runner Secret;
      # "irsa" omits them (relies on the SA's eks.amazonaws.com/role-arn annotation).
      # Until the upstream runner supports the AWS default credential chain (see
      # docs/upstream-issues/runner-irsa-support.md), runtime IRSA is non-functional;
      # for first-pass testing, use "static".
      credentialMode: "${RUNNER_AWS_CREDENTIAL_MODE}"
      allowEmptyStaticKeyShim: false
    serviceAccount:
      create: true
      annotations:
        # Empty when credentialMode=static; populated when credentialMode=irsa.
        eks.amazonaws.com/role-arn: "${IRSA_ROLE_ARN}"
      automountServiceAccountToken: true
    env:
      AWS_REGION: "${AWS_REGION}"
      AWS_ENDPOINT_URL: ""
      AWS_DEFAULT_BUCKET: "${S3_BUCKET}"
      AWS_ACCESS_KEY_ID: "${IAM_ACCESS_KEY}"
      AWS_SECRET_ACCESS_KEY: "${IAM_SECRET_KEY}"
    dockerInstaller:
      dynamicHostAliases: []
      insecureRegistries: []
