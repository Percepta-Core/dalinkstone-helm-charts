# daytona (full OSS self-hosted) helm values - Azure / AKS, K8s-native flow.
# Rendered by scripts/azure-oss-setup/up.sh via envsubst against operator prompts.
#
# THIS IS THE FULL SELF-HOSTED OSS DEPLOYMENT. Everything runs inside the AKS
# cluster: API server, Postgres, Redis, MinIO (object storage), Harbor (registry),
# Dex (auth), proxy, runner DaemonSet. No Daytona Cloud control plane. No
# external dependencies beyond DNS + Let's Encrypt.
#
# Required ${VAR} placeholders (set by up.sh from prompts or computed):
#   BASE_DOMAIN              - public DNS base, e.g. daytona.mycompany.com
#                              API at https://${BASE_DOMAIN}
#                              proxy/sandboxes at https://*.${BASE_DOMAIN}
#                              dex (auth) at https://dex.${BASE_DOMAIN}
#                              harbor (registry) at https://harbor.${BASE_DOMAIN}
#   CLUSTER_ISSUER           - cert-manager ClusterIssuer name (letsencrypt-prod)
#   POSTGRES_PASSWORD        - postgres root password (auto-generated by up.sh)
#   REDIS_PASSWORD           - redis auth password (auto-generated)
#   MINIO_ROOT_PASSWORD      - MinIO root password (auto-generated)
#   HARBOR_ADMIN_PASSWORD    - Harbor admin password (auto-generated)
#   RUNNER_IMAGE_TAG         - daytona-runner image tag (default v0.183.0)
#   INTERNAL_REGISTRY_HOST   - optional cluster-DNS hostname for an additional
#                              internal Docker registry (empty = none)

baseDomain: "${BASE_DOMAIN}"

global:
  storageClass: "managed-csi"

services:
  api:
    image:
      tag: "v0.184.0-k8s-oss.3-amd64"
    ingress:
      enabled: true
      className: "nginx"
      tls: true
      selfSigned: false
      annotations:
        cert-manager.io/cluster-issuer: "${CLUSTER_ISSUER}"
        nginx.ingress.kubernetes.io/ssl-redirect: "true"
        nginx.ingress.kubernetes.io/proxy-body-size: "0"

  proxy:
    image:
      tag: "v0.184.0-k8s-oss.3-amd64"
    ingress:
      enabled: true
      className: "nginx"
      tls: true
      selfSigned: false
      annotations:
        cert-manager.io/cluster-issuer: "${CLUSTER_ISSUER}"
        nginx.ingress.kubernetes.io/ssl-redirect: "true"
        nginx.ingress.kubernetes.io/proxy-read-timeout: "3600"
        nginx.ingress.kubernetes.io/proxy-send-timeout: "3600"

  sshGateway:
    enabled: true
    image:
      tag: "v0.184.0-k8s-oss.3-amd64"

  runnermanager:
    image:
      tag: "v0.184.0-k8s-oss.3-amd64"

  runner:
    enabled: true
    image:
      tag: "v0.184.0-k8s-oss.3-amd64"
    dockerInstaller:
      dynamicHostAliases: []
      insecureRegistries: []

dex:
  enabled: true
  ingress:
    enabled: true
    className: "nginx"
    tls: true
    annotations:
      cert-manager.io/cluster-issuer: "${CLUSTER_ISSUER}"
      nginx.ingress.kubernetes.io/ssl-redirect: "true"

postgresql:
  enabled: true
  auth:
    postgresPassword: "${POSTGRES_PASSWORD}"
    database: "daytona"
  primary:
    persistence:
      enabled: true
      size: 20Gi
      storageClass: "managed-csi"
    resources:
      requests:
        cpu: 500m
        memory: 1Gi
      limits:
        cpu: 2000m
        memory: 4Gi

redis:
  enabled: true
  architecture: standalone
  auth:
    enabled: true
    password: "${REDIS_PASSWORD}"
  master:
    persistence:
      enabled: true
      size: 8Gi
      storageClass: "managed-csi"

minio:
  enabled: true
  rootUser: "minio-admin"
  rootPassword: "${MINIO_ROOT_PASSWORD}"
  persistence:
    enabled: true
    size: 100Gi
    storageClass: "managed-csi"
  mode: standalone

harbor:
  enabled: true
  externalURL: "https://harbor.${BASE_DOMAIN}"
  expose:
    type: ingress
    tls:
      enabled: true
      certSource: secret
      secret:
        secretName: "harbor.${BASE_DOMAIN}-tls"
    ingress:
      className: nginx
      annotations:
        cert-manager.io/cluster-issuer: "${CLUSTER_ISSUER}"
        nginx.ingress.kubernetes.io/ssl-redirect: "true"
        nginx.ingress.kubernetes.io/proxy-body-size: "0"
      hosts:
        core: "harbor.${BASE_DOMAIN}"
  harborAdminPassword: "${HARBOR_ADMIN_PASSWORD}"
  persistence:
    persistentVolumeClaim:
      registry:
        size: 200Gi
        storageClass: "managed-csi"
      database:
        size: 10Gi
        storageClass: "managed-csi"
      redis:
        size: 5Gi
        storageClass: "managed-csi"
