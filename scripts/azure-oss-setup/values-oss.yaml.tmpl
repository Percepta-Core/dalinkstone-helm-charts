# daytona (full OSS self-hosted) helm values - Azure / AKS, K8s-native flow.
# Rendered by scripts/azure-oss-setup/up.sh via envsubst against operator prompts.
#
# THIS IS THE FULL SELF-HOSTED OSS DEPLOYMENT. Everything runs inside the AKS
# cluster: API server, Postgres, Redis, MinIO (object storage), Harbor (registry),
# Dex (auth), proxy, runner DaemonSet. No Daytona Cloud control plane. No
# external dependencies beyond DNS + Let's Encrypt.
#
# Required ${VAR} placeholders (set by up.sh from prompts or computed):
#   BASE_DOMAIN              - public DNS base, e.g. daytona.mycompany.com
#                              API at https://${BASE_DOMAIN}
#                              proxy/sandboxes at https://*.${BASE_DOMAIN}
#                              dex (auth) at https://dex.${BASE_DOMAIN}
#                              harbor (registry) at https://harbor.${BASE_DOMAIN}
#   POSTGRES_PASSWORD        - postgres root password (auto-generated by up.sh)
#   REDIS_PASSWORD           - redis auth password (auto-generated)
#   MINIO_ROOT_PASSWORD      - MinIO root password (auto-generated)
#   HARBOR_ADMIN_PASSWORD    - Harbor admin password (auto-generated)
#   RUNNER_IMAGE_TAG         - daytona image tag for api/proxy/runner/runnermanager/ssh-gateway
#   INTERNAL_REGISTRY_HOST   - optional cluster-DNS hostname for an additional
#                              internal Docker registry (empty = none)
#
# TLS placeholders (filled by up.sh based on TLS_MODE prompt):
#   CERT_MANAGER_ANNOTATION  - either the cert-manager annotation line (for
#                              cloudflare-dns01) or empty (for self-signed / manual).
#                              When empty the ingress has no cert-manager annotation,
#                              which means cert-manager will NOT auto-provision a
#                              cert for that ingress.
#   INGRESS_SELFSIGNED       - "true" or "false"; sets ingress.selfSigned on
#                              api/proxy/dex which makes the chart generate a
#                              self-signed cert via Helm's genSignedCert.
#   HARBOR_CERT_SOURCE       - "secret" (cert-manager or operator-provided)
#                              or "auto" (Harbor generates its own self-signed).

baseDomain: "${BASE_DOMAIN}"

global:
  storageClass: "managed-csi"

services:
  api:
    image:
      tag: "${RUNNER_IMAGE_TAG}"
    env:
      # REQUIRED at first boot: becomes the Daytona Admin user's API key.
      # Missing env => api getOrThrow('admin.apiKey') throws => CrashLoopBackOff.
      ADMIN_API_KEY: "${ADMIN_API_KEY}"
      # Encryption-at-rest material (replaces the chart's CHANGE_ME placeholders).
      ENCRYPTION_KEY: "${ENCRYPTION_KEY}"
      ENCRYPTION_SALT: "${ENCRYPTION_SALT}"
    ingress:
      enabled: true
      className: "nginx"
      tls: true
      selfSigned: ${INGRESS_SELFSIGNED}
      annotations:
${CERT_MANAGER_ANNOTATION}
        nginx.ingress.kubernetes.io/ssl-redirect: "true"
        nginx.ingress.kubernetes.io/proxy-body-size: "0"

  proxy:
    image:
      tag: "${RUNNER_IMAGE_TAG}"
    ingress:
      enabled: true
      className: "nginx"
      tls: true
      selfSigned: ${INGRESS_SELFSIGNED}
      annotations:
${CERT_MANAGER_ANNOTATION}
        nginx.ingress.kubernetes.io/ssl-redirect: "true"
        nginx.ingress.kubernetes.io/proxy-read-timeout: "3600"
        nginx.ingress.kubernetes.io/proxy-send-timeout: "3600"

  sshGateway:
    enabled: true
    image:
      tag: "${RUNNER_IMAGE_TAG}"

  runnermanager:
    image:
      tag: "${RUNNER_IMAGE_TAG}"
    env:
      # Ensure the manager bootstraps (registers + configures) at least one
      # runner on the sandbox node pool of a fresh cluster.
      MIN_RUNNERS: "1"

  runner:
    enabled: true
    image:
      tag: "${RUNNER_IMAGE_TAG}"
    dockerInstaller:
      dynamicHostAliases: []
      # In self-signed TLS mode the runner's dockerd pushes/pulls snapshots
      # against harbor.<baseDomain> whose cert is not CA-signed; docker then
      # fails with "x509: certificate signed by unknown authority" and the
      # default snapshot lands in state=error. up.sh sets this to
      # ["harbor.<baseDomain>"] for self-signed and [] otherwise.
      insecureRegistries: ${INSECURE_REGISTRIES}

dex:
  enabled: true
  ingress:
    enabled: true
    className: "nginx"
    tls: true
    selfSigned: ${INGRESS_SELFSIGNED}
    annotations:
${CERT_MANAGER_ANNOTATION}
        nginx.ingress.kubernetes.io/ssl-redirect: "true"

postgresql:
  enabled: true
  auth:
    postgresPassword: "${POSTGRES_PASSWORD}"
    database: "daytona"
  primary:
    persistence:
      enabled: true
      size: 20Gi
      storageClass: "managed-csi"
    resources:
      requests:
        cpu: 500m
        memory: 1Gi
      limits:
        cpu: 2000m
        memory: 4Gi

redis:
  enabled: true
  architecture: standalone
  auth:
    enabled: true
    password: "${REDIS_PASSWORD}"
  master:
    persistence:
      enabled: true
      size: 8Gi
      storageClass: "managed-csi"

minio:
  enabled: true
  rootUser: "minio-admin"
  rootPassword: "${MINIO_ROOT_PASSWORD}"
  persistence:
    enabled: true
    size: 100Gi
    storageClass: "managed-csi"
  mode: standalone

harbor:
  enabled: true
  externalURL: "https://harbor.${BASE_DOMAIN}"
  expose:
    type: ingress
    tls:
      enabled: true
      certSource: ${HARBOR_CERT_SOURCE}
      secret:
        # Harbor can share the same wildcard certificate as API/Proxy in this
        # flow, so we point at the base-domain secret instead of a Harbor-only
        # secret. This avoids issuing an extra cert for just
        # harbor.<baseDomain>, which has proven to leave Harbor TLS missing and
        # break snapshot pulls.
        secretName: "${BASE_DOMAIN}-tls"
    ingress:
      className: nginx
      annotations:
${CERT_MANAGER_ANNOTATION}
        nginx.ingress.kubernetes.io/ssl-redirect: "true"
        nginx.ingress.kubernetes.io/proxy-body-size: "0"
      hosts:
        core: "harbor.${BASE_DOMAIN}"
  harborAdminPassword: "${HARBOR_ADMIN_PASSWORD}"
  persistence:
    persistentVolumeClaim:
      registry:
        size: 200Gi
        storageClass: "managed-csi"
      database:
        size: 10Gi
        storageClass: "managed-csi"
      redis:
        size: 5Gi
        storageClass: "managed-csi"
