# BYOC OSS Azure test fixture — deterministic placeholder values for static QA.
# Consumed by hack/check-helm-values-templates.sh to render
# scripts/azure-oss-setup/values-oss.yaml.tmpl via envsubst, then helm template+lint
# against charts/daytona (the FULL OSS chart, NOT daytona-region).
# NOT real credentials — these strings match shape, not content.
BASE_DOMAIN="daytona-oss-test.example.com"
CLUSTER_ISSUER="letsencrypt-prod"
POSTGRES_PASSWORD="postgres-test-only-not-real-AAAAAAAAAAAAAAAA"
REDIS_PASSWORD="redis-test-only-not-real-BBBBBBBBBBBBBBBB"
MINIO_ROOT_PASSWORD="minio-test-only-not-real-CCCCCCCCCCCCCCCC"
HARBOR_ADMIN_PASSWORD="harbor-test-only-not-real-DDDDDDDD"
RUNNER_IMAGE_TAG="v0.184.0-k8s-oss.3-amd64"
INTERNAL_REGISTRY_HOST=""
CERT_MANAGER_ANNOTATION='        cert-manager.io/cluster-issuer: "letsencrypt-prod"'
INGRESS_SELFSIGNED="false"
HARBOR_CERT_SOURCE="secret"
