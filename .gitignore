# Environment specific files — block stray dotenv files anywhere in the tree.
# Patterns cover .env (root or any subdir), .env.* (e.g. .env.local), and
# *.env / *.envrc (e.g. test.env, prod.env, some-secret.envrc). Negation
# re-allows .env.example (operator-facing template) and tracked QA fixtures
# under scripts/<cloud>-setup/.tests/*.env which static-check scripts source
# via envsubst. Anything else is treated as operator-private.
.env
.env.*
.envrc
*.env
*.envrc
!.env.example
!**/.env.example
!scripts/*-setup/.tests/*.env

